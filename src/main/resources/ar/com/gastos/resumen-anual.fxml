<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ar.com.gastos.controller.ResumenAnualController"
      spacing="12" style="-fx-padding:20; -fx-background-color:#f4f4f4;">

    <!-- Título -->
    <Label fx:id="lblAnio"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#2c3e50;"/>

    <!-- Tabs -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- Tab 1: Resumen mensual (existente) -->
        <Tab text="Resumen Mensual">
            <VBox spacing="10" style="-fx-padding:10;">
                <TableView fx:id="tablaResumen" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMes"      text="Mes"      prefWidth="160"/>
                        <TableColumn fx:id="colIngresos" text="Ingresos" prefWidth="170"/>
                        <TableColumn fx:id="colEgresos"  text="Egresos"  prefWidth="170"/>
                        <TableColumn fx:id="colBalance"  text="Balance"  prefWidth="170"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
                <HBox spacing="40" alignment="CENTER_LEFT"
                      style="-fx-background-color:#2c3e50; -fx-padding:12 16; -fx-background-radius:6;">
                    <Label fx:id="lblTotalIngresos" style="-fx-text-fill:#2ecc71; -fx-font-size:13; -fx-font-weight:bold;"/>
                    <Label fx:id="lblTotalEgresos"  style="-fx-text-fill:#e74c3c; -fx-font-size:13; -fx-font-weight:bold;"/>
                    <Label fx:id="lblTotalBalance"  style="-fx-text-fill:white;   -fx-font-size:14; -fx-font-weight:bold;"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- Tab 2: Por tarjeta -->
        <Tab text="Por Tarjeta">
            <VBox spacing="10" style="-fx-padding:10;">
                <!-- Selector de tarjeta -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Tarjeta:" style="-fx-font-weight:bold;"/>
                    <ComboBox fx:id="cmbTarjeta" prefWidth="250"
                              onAction="#onTarjetaSeleccionada"/>
                </HBox>
                <!-- Tabla dinámica -->
                <TableView fx:id="tablaTarjeta" VBox.vgrow="ALWAYS">
                </TableView>
                <!-- Totales pie -->
                <HBox fx:id="hboxTotalesTarjeta" spacing="30" alignment="CENTER_LEFT"
                      style="-fx-background-color:#2c3e50; -fx-padding:10 16; -fx-background-radius:6;">
                    <Label fx:id="lblTotTarjeta1" style="-fx-text-fill:white; -fx-font-size:12; -fx-font-weight:bold;"/>
                    <Label fx:id="lblTotTarjeta2" style="-fx-text-fill:#2ecc71; -fx-font-size:12; -fx-font-weight:bold;"/>
                    <Label fx:id="lblTotTarjeta3" style="-fx-text-fill:#e74c3c; -fx-font-size:12; -fx-font-weight:bold;"/>
                    <Label fx:id="lblTotTarjeta4" style="-fx-text-fill:#f39c12; -fx-font-size:12; -fx-font-weight:bold;"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- Tab 3: Por categoría -->
        <Tab text="Por Categoria">
            <VBox spacing="10" style="-fx-padding:10;">
                <TableView fx:id="tablaCategoria" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="200"/>
                        <TableColumn fx:id="colTotalCat"  text="Total"     prefWidth="180"/>
                        <TableColumn fx:id="colPorcentaje" text="'% del total'" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
                <HBox spacing="30" alignment="CENTER_LEFT"
                      style="-fx-background-color:#2c3e50; -fx-padding:10 16; -fx-background-radius:6;">
                    <Label fx:id="lblTotalCategoria"
                           style="-fx-text-fill:white; -fx-font-size:13; -fx-font-weight:bold;"/>
                </HBox>
            </VBox>
        </Tab>

    </TabPane>

</VBox>
