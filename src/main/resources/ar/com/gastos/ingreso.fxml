<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="ar.com.gastos.controller.IngresoController"
      spacing="10" alignment="CENTER" style="-fx-padding:20;">
    <Label text="Registrar Ingreso" style="-fx-font-size:18; -fx-font-weight:bold;"/>
    <TextField fx:id="txtTipoIngreso" promptText="Tipo de ingreso (ej: Sueldo, Venta)"/>
    <TextField fx:id="txtMonto" promptText="Monto"/>
    <Button text="Guardar" onAction="#guardarIngreso"/>
</VBox>
