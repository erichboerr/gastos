<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="ar.com.gastos.controller.IngresoController"
      spacing="10" alignment="TOP_CENTER" style="-fx-padding:20;" prefWidth="620">

    <Label text="Ingresos" style="-fx-font-size:18; -fx-font-weight:bold;"/>

    <Separator/>

    <!-- Formulario de alta / edición -->
    <Label text="Tipo de ingreso"/>
    <ComboBox fx:id="cmbTipoIngreso" promptText="Tipo de ingreso" editable="true" maxWidth="Infinity"/>

    <Label text="Fecha"/>
    <DatePicker fx:id="dpFecha" promptText="Fecha" maxWidth="Infinity"/>

    <Label text="Monto"/>
    <TextField fx:id="txtMonto" promptText="Monto" maxWidth="Infinity"/>

    <HBox spacing="8">
        <Button text="Guardar" onAction="#guardarIngreso"
                style="-fx-background-color:#2c3e50; -fx-text-fill:white; -fx-font-weight:bold;"
                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button text="Limpiar" onAction="#limpiar"
                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button text="Cerrar" onAction="#cerrar"
                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>

    <Separator/>

    <!-- Navegación por mes -->
    <HBox spacing="10" alignment="CENTER" style="-fx-padding:4 10 4 10; -fx-background-color:#f0f0f0;">
        <Button text="◀" onAction="#meAnterior"
                style="-fx-background-color:transparent; -fx-font-size:14; -fx-cursor:hand;"/>
        <Label fx:id="lblMes"
               style="-fx-font-size:14; -fx-font-weight:bold;" minWidth="140" alignment="CENTER"/>
        <Button text="▶" onAction="#meSiguiente"
                style="-fx-background-color:transparent; -fx-font-size:14; -fx-cursor:hand;"/>
        <Label fx:id="lblTotalMes" style="-fx-font-size:13; -fx-text-fill:#27ae60;"/>
    </HBox>

    <!-- Lista de ingresos del mes -->
    <TableView fx:id="tablaIngresos" prefHeight="250" maxWidth="Infinity">
        <columns>
            <TableColumn fx:id="colFecha"    text="Fecha"    prefWidth="110"/>
            <TableColumn fx:id="colTipo"     text="Tipo"     prefWidth="160"/>
            <TableColumn fx:id="colMonto"    text="Monto"    prefWidth="130"/>
            <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="170"/>
        </columns>
    </TableView>

</VBox>