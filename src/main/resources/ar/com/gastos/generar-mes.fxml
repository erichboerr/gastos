<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ar.com.gastos.controller.GenerarMesController"
      spacing="12" alignment="TOP_CENTER" style="-fx-padding:20;"
      prefWidth="520">

    <Label text="Generar Gastos del Mes"
           style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#2c3e50;"/>

    <Separator/>

    <!-- Lista de recurrentes — fecha y monto por ítem -->
    <Label text="Seleccioná los gastos a generar"/>
    <ListView fx:id="lstItems" prefHeight="300"/>

    <Separator/>

    <HBox spacing="8">
        <Button text="Generar seleccionados"
                onAction="#generarEgresos"
                style="-fx-background-color:#2c3e50; -fx-text-fill:white; -fx-font-weight:bold;"
                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button text="Limpiar" onAction="#limpiar"
                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button text="Cerrar" onAction="#cerrar"
                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>
</VBox>