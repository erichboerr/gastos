<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="ar.com.gastos.controller.DetalleController"
>
    <top>
        <VBox>
            <!-- Título -->
            <Label fx:id="lblTitulo" text="Detalle de movimientos"
                   style="-fx-font-size:16; -fx-font-weight:bold; -fx-padding:10;"/>

            <!-- Barra superior en 3 bloques: 1/4 - 2/4 - 1/4 -->
            <GridPane style="-fx-padding:6 10 8 10; -fx-background-color:#f0f0f0;">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>

                <!-- Bloque 1/4 — navegación de mes -->
                <HBox spacing="6" alignment="CENTER_LEFT" GridPane.columnIndex="0">
                    <Button text="◀" onAction="#meAnterior"
                            style="-fx-background-color:transparent; -fx-font-size:14; -fx-cursor:hand;"/>
                    <Label fx:id="lblMes"
                           style="-fx-font-size:14; -fx-font-weight:bold;" minWidth="120" alignment="CENTER"/>
                    <Button text="▶" onAction="#meSiguiente"
                            style="-fx-background-color:transparent; -fx-font-size:14; -fx-cursor:hand;"/>
                </HBox>

                <!-- Bloque 2/4 — consumos, pagos, saldo -->
                <HBox spacing="14" alignment="CENTER" GridPane.columnIndex="1">
                    <Label fx:id="lblConsumos" style="-fx-font-size:12; -fx-text-fill:#2c3e50;"/>
                    <Label fx:id="lblPagos" style="-fx-font-size:12; -fx-text-fill:#27ae60;"/>
                    <Label fx:id="lblSaldo" style="-fx-font-size:12; -fx-font-weight:bold;"/>
                </HBox>

                <!-- Bloque 1/4 — botón PDF -->
                <HBox alignment="CENTER_RIGHT" GridPane.columnIndex="2">
                    <Button fx:id="btnPdf" text="PDF" onAction="#exportarPdf"
                            style="-fx-background-color:#c0392b; -fx-text-fill:white; -fx-font-weight:bold;"/>
                </HBox>

            </GridPane>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tablaMovimientos">
            <columns>
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="110"/>
                <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="220"/>
                <TableColumn fx:id="colComentario" text="Comentario" prefWidth="220"/>
                <TableColumn fx:id="colMonto" text="Monto" prefWidth="120"/>
                <TableColumn fx:id="colCuota" text="Tipo" prefWidth="100"/>
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="180"/>
            </columns>
        </TableView>
    </center>
</BorderPane>