<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="ar.com.gastos.controller.DetalleController">
    <top>
        <VBox>
            <!-- Título -->
            <Label fx:id="lblTitulo" text="Detalle de movimientos"
                   style="-fx-font-size:16; -fx-font-weight:bold; -fx-padding:10;"/>
            <!-- Navegación por mes -->
            <!-- Navegación por mes + resumen -->
            <HBox spacing="10" alignment="CENTER" style="-fx-padding:4 10 8 10; -fx-background-color:#f0f0f0;">
                <Button text="◀" onAction="#meAnterior"
                        style="-fx-background-color:transparent; -fx-font-size:14; -fx-cursor:hand;"/>
                <Label fx:id="lblMes"
                       style="-fx-font-size:14; -fx-font-weight:bold;" minWidth="140" alignment="CENTER"/>
                <Button text="▶" onAction="#meSiguiente"
                        style="-fx-background-color:transparent; -fx-font-size:14; -fx-cursor:hand;"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="lblConsumos" style="-fx-font-size:12; -fx-text-fill:#2c3e50;"/>
                <Label fx:id="lblPagos"    style="-fx-font-size:12; -fx-text-fill:#27ae60;"/>
                <Label fx:id="lblSaldo"    style="-fx-font-size:12; -fx-font-weight:bold;"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tablaMovimientos">
            <columns>
                <TableColumn fx:id="colFecha"       text="Fecha"       prefWidth="110"/>
                <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="260"/>
                <TableColumn fx:id="colMonto"       text="Monto"       prefWidth="120"/>
                <TableColumn fx:id="colCuota"       text="Tipo"         prefWidth="90"/>
                <TableColumn fx:id="colAcciones"    text="Acciones"    prefWidth="220"/>
            </columns>
        </TableView>
    </center>
</BorderPane>