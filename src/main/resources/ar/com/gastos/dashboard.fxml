<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ar.com.gastos.controller.DashboardController"
            stylesheets="@styles/cards.css">

    <!-- HEADER -->
    <top>
        <HBox style="-fx-background-color:#2c3e50; -fx-padding:16 20;" spacing="30" alignment="CENTER_LEFT">

            <Label text="Control de Gastos"
                   style="-fx-text-fill:white; -fx-font-size:18; -fx-font-weight:bold;"/>

            <HBox spacing="10" alignment="CENTER">
                <Button text="◀" onAction="#meAnterior"
                        style="-fx-background-color:transparent; -fx-text-fill:white; -fx-font-size:16; -fx-cursor:hand;"/>
                <Label fx:id="lblMesNavegacion"
                       style="-fx-text-fill:white; -fx-font-size:15; -fx-font-weight:bold;" minWidth="140" alignment="CENTER"/>
                <Button text="▶" onAction="#meSiguiente"
                        style="-fx-background-color:transparent; -fx-text-fill:white; -fx-font-size:16; -fx-cursor:hand;"/>
            </HBox>

            <HBox spacing="30" alignment="CENTER" HBox.hgrow="ALWAYS">
                <Label fx:id="lblIngresos" style="-fx-text-fill:#2ecc71; -fx-font-size:13;"/>
                <Label fx:id="lblEgresos"  style="-fx-text-fill:#e74c3c; -fx-font-size:13;"/>
                <Label fx:id="lblBalance"  style="-fx-text-fill:white;   -fx-font-size:14; -fx-font-weight:bold;"/>
            </HBox>

        </HBox>
    </top>

    <!-- MENÚ LATERAL
         prefHeight="10000" es el truco estándar en JavaFX para que un VBox
         dentro de BorderPane.left se estire hasta ocupar toda la altura disponible.
         El BorderPane se encarga de recortarlo al tamaño real de la ventana. -->
    <left>
        <VBox style="-fx-background-color:#D1CCCB; -fx-padding:20;"
              spacing="12" alignment="TOP_CENTER" prefHeight="10000">
            <Label text="Tarjetas"
                   style="-fx-text-fill:black; -fx-font-size:16; -fx-font-weight:bold;"/>
            <Button text="Nueva Tarjeta"  onAction="#abrirNuevaTarjeta"  maxWidth="Infinity"/>
            <Separator/>
            <Label text="Movimientos"
                   style="-fx-text-fill:black; -fx-font-size:16; -fx-font-weight:bold;"/>
            <Button text="Ingresos"       onAction="#abrirIngreso"       maxWidth="Infinity"/>
            <Button text="Egresos"        onAction="#abrirEgreso"        maxWidth="Infinity"/>
            <Button text="Pagos"          onAction="#abrirPago"          maxWidth="Infinity"/>
            <Separator/>
            <Label text="Carga de datos"
                   style="-fx-text-fill:black; -fx-font-size:16; -fx-font-weight:bold;"/>
            <Button text="Recurrentes" onAction="#abrirRecurrentes" maxWidth="Infinity"/>
            <Button text="Comercios" onAction="#abrirComercios" maxWidth="Infinity"/>
            <Button text="Generar Mes" onAction="#abrirGenerarMes" maxWidth="Infinity"/>
            <Button text="Cierres"        onAction="#abrirCierreTarjeta" maxWidth="Infinity"/>
            <Separator/>
            <Label text="Resumenes"
                   style="-fx-text-fill:black; -fx-font-size:16; -fx-font-weight:bold;"/>
            <Button text="Resumen Anual"  onAction="#abrirResumenAnual"  maxWidth="Infinity"/>

            <Separator/>
            <Button text="Backup DB" onAction="#ejecutarBackup" maxWidth="Infinity"
                    style="-fx-background-color:#8e44ad; -fx-text-fill:white; -fx-font-weight:bold;"/>

        </VBox>
    </left>

    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-color:transparent; -fx-padding:20;">
            <VBox spacing="20" alignment="CENTER">
                <VBox fx:id="cardIngresos" alignment="CENTER"/>
                <GridPane fx:id="cardsPane" hgap="30" vgap="30" alignment="CENTER"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
