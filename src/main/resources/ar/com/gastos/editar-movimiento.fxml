<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ar.com.gastos.controller.EditarMovimientoController"
      spacing="10" alignment="TOP_CENTER" style="-fx-padding:20;"
      prefWidth="400" prefHeight="420">

    <Label text="Editar Movimiento"
           style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#2c3e50;"/>

    <Separator/>

    <Label text="Fecha"/>
    <DatePicker fx:id="dpFecha" maxWidth="Infinity"/>

    <!-- Para EGRESO: ComboBox de comercios -->
    <Label fx:id="lblComercio" text="Comercio"/>
    <ComboBox fx:id="cmbComercio" maxWidth="Infinity"/>

    <!-- Para PAGO: TextField libre -->
    <Label fx:id="lblDescripcion" text="Descripción"/>
    <TextField fx:id="txtDescripcion" maxWidth="Infinity"/>

    <Label text="Monto"/>
    <TextField fx:id="txtMonto" maxWidth="Infinity"/>

    <Label text="Comentario (opcional)"/>
    <TextField fx:id="txtComentario" maxWidth="Infinity"/>

    <Label fx:id="lblCuotas" text="Cuotas"/>
    <TextField fx:id="txtCuotas" maxWidth="Infinity"/>

    <Separator/>

    <Button text="Guardar cambios"
            onAction="#guardar"
            maxWidth="Infinity"
            style="-fx-background-color:#2c3e50; -fx-text-fill:white; -fx-font-weight:bold;"/>

</VBox>